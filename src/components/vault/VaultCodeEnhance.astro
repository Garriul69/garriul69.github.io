---
/** Añade botón copiar a bloques .code-block generados en build time. */
---

<script is:inline>
  (function () {
    var COPY = '<svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="5" y="5" width="8" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M4 11V3.5A1.5 1.5 0 015.5 2H11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>';
    var CHECK = '<svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3.5 8.5l3 3 6-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

    function enhance() {
      document.querySelectorAll('.vault-prose .code-block').forEach(function (block) {
        if (block.querySelector('.code-block__copy')) return;

        var pre = block.querySelector('pre');
        if (!pre) return;

        pre.removeAttribute('style');
        pre.removeAttribute('tabindex');

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'code-block__copy';
        btn.setAttribute('aria-label', 'Copiar código');
        btn.innerHTML = COPY;
        block.insertBefore(btn, pre);

        btn.addEventListener('click', function () {
          var text = pre.querySelector('code') ? pre.querySelector('code').textContent : pre.textContent;
          navigator.clipboard.writeText(text || '').then(function () {
            btn.classList.add('is-copied');
            btn.innerHTML = CHECK;
            setTimeout(function () {
              btn.classList.remove('is-copied');
              btn.innerHTML = COPY;
            }, 1800);
          }).catch(function () {});
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', enhance);
    } else {
      enhance();
    }
  })();
</script>
