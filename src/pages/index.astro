---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
---

<Layout>
  <Hero />

  <!-- Placeholder sections so anchor links resolve -->
  <section id="experience" style="min-height:100vh;display:flex;align-items:center;justify-content:center;">
    <p style="color:var(--color-muted);font-family:var(--font-mono);font-size:0.875rem;">
      Experience section — coming soon
    </p>
  </section>

  <section id="stack" style="min-height:60vh;display:flex;align-items:center;justify-content:center;">
    <p style="color:var(--color-muted);font-family:var(--font-mono);font-size:0.875rem;">
      Stack section — coming soon
    </p>
  </section>

  <section id="projects" style="min-height:60vh;display:flex;align-items:center;justify-content:center;">
    <p style="color:var(--color-muted);font-family:var(--font-mono);font-size:0.875rem;">
      Projects section — coming soon
    </p>
  </section>

  <section id="contact" style="min-height:60vh;display:flex;align-items:center;justify-content:center;">
    <p style="color:var(--color-muted);font-family:var(--font-mono);font-size:0.875rem;">
      Contact section — coming soon
    </p>
  </section>
</Layout>
